{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run All Elixir Tests",
      "type": "shell",
      "command": "mix test",
      "group": "test",
      "presentation": { "echo": true, "reveal": "always", "focus": false, "panel": "shared" }
    },
    {
      "label": "Run Current Elixir Test File",
      "type": "shell",
      "command": "mix test ${relativeFile}",
      "group": "test",
      "presentation": { "echo": true, "reveal": "always", "focus": true, "panel": "shared" }
    },
    {
      "label": "Run Elixir Test at Current Line",
      "type": "shell",
      "command": "mix test ${relativeFile}:${lineNumber}",
      "group": "test",
      "presentation": { "echo": true, "reveal": "always", "focus": true, "panel": "shared" }
    }
  ]
}